# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=govinfo_db

# ── JWT ────────────────────────────────────────────────────────
# Replace with a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────
PORT=5000

# ── Gemini AI (Phase 7 — Chatbot) ──────────────────────────────
# Obtain a free API key from: https://aistudio.google.com/app/apikey
# Supports Google Search grounding on the free tier.
GEMINI_API_KEY=your_gemini_api_key_here
